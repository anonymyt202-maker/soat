# Bot Token (BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# Bot Username (@ belgisisiz)
BOT_USERNAME=your_bot_username

# Admin ID lar (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# Telegram API (my.telegram.org dan oling)
API_ID=your_api_id
API_HASH=your_api_hash

# Session Encryption Key (32 belgili ixtiyoriy kalit)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Developer/Support Username (@ bilan)
DEV_USERNAME=@your_dev_username
